#!/bin/sh

set -eu

ZIG_PUBLIC_KEY="RWSGOq2NVecA2UPNdBUZykf1CCb147pkmdtYxgb3Ti+JO/wCYvhbAb/U"
ZIG_MIRRORS_URL="https://ziglang.org/download/community-mirrors.txt"
# The list of mirrors as of 2026-02-21 as a backup if ziglang.org is unavailable
ZIG_FALLBACK_MIRRORS="$(
    cat <<EOF
https://pkg.machengine.org/zig
https://zigmirror.hryx.net/zig
https://zig.linus.dev/zig
https://zig.squirl.dev
https://zig.florent.dev
https://zig.mirror.mschae23.de/zig
https://zigmirror.meox.dev
https://ziglang.freetls.fastly.net
https://zig.tilok.dev
https://zig-mirror.tsimnet.eu/zig
https://zig.karearl.com/zig
https://pkg.earth/zig
https://fs.liujiacai.net/zigbuilds
EOF
)"

fetch_url() {
    if [ -z "$1" ]; then
        echo "no URL passed to 'fetch_url'" >&2
        return 1
    fi

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$1"
        return $?
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -qO- "$1"
        return $?
    fi

    return 127
}

make_tempdir() {
    [ -n "$1" ] || {
        echo "no parent directory passed to 'make_tempdir'" >&2
        return 1
    }

    [ -d "$1" ] || {
        echo "parent directory in 'make_tempdir' must exist" >&2
        return 1
    }

    _tmpdir="$(mktemp -d "$1/.zig-tmp.XXXXXXXX" 2>/dev/null || true)"
    if [ -n "${_tmpdir}" ] && [ -d "${_tmpdir}" ]; then
        printf "%s\n" "${_tmpdir}"
        return 0
    fi

    mktemp -d -t "zig-tmp.XXXXXXXX"
}

shuffle_lines() {
    awk '
        NF { a[++n] = $0 }
        END {
            srand()
            for (i = n; i > 1; i--) {
                j = int(rand() * i) + 1
                t = a[i]; a[i] = a[j]; a[j] = t
            }
            for (i = 1; i <= n; i++) print a[i]
        }
    '
}

download_archive() {
    [ -n "$1" ] || {
        echo "no URL passed to 'download_archive'" >&2
        return 1
    }

    [ -n "$2" ] || {
        echo "no output passed to 'download_archive'" >&2
        return 1
    }

    _url="$1"
    _out="$2"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSLo "${_out}" "${_url}"
        return $?
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -qO "${_out}" "${_url}"
        return $?
    fi

    return 127
}

main() {
    [ $# -ge 2 ] || {
        echo "usage: download_zig version destdir" >&2
        return 1
    }

    [ -n "$1" ] || {
        echo "no Zig version argument passed to 'download_zig'" >&2
        return 1
    }

    [ -n "$2" ] || {
        echo "no destination directory argument passed to 'download_zig'" >&2
        return 1
    }

    _zig_version="$1"
    _dest_dir="$2"

    if [ "$(uname -m)" = "arm64" ] || [ "$(uname -m)" = "aarch64" ]; then
        _arch="aarch64"
    else
        _arch="x86_64"
    fi

    case "$(uname)" in
    Darwin)
        _os="macos"
        _archive_extension=".tar.xz"
        ;;
    FreeBSD)
        _os="freebsd"
        _archive_extension=".tar.xz"
        ;;
    Linux)
        _os="linux"
        _archive_extension=".tar.xz"
        ;;
    *)
        echo "unsupported operating system: $(uname)" >&2
        return 1
        ;;
    esac

    _archive_dir_parent="$(dirname -- "${_dest_dir}")"
    mkdir -p "${_archive_dir_parent}"

    _archive="zig-${_arch}-${_os}-${_zig_version}${_archive_extension}"
    _archive_dir="$(make_tempdir "${_archive_dir_parent}")"
    trap 'rm -rf "${_archive_dir}"' EXIT INT TERM HUP

    _archive_dest="${_archive_dir}/${_archive}"

    _mirror_list_ordered="$(fetch_url "${ZIG_MIRRORS_URL}" 2>/dev/null || printf "%s\n" "${ZIG_FALLBACK_MIRRORS}")"
    _mirror_list="$(printf "%s\n" "${_mirror_list_ordered}" | awk 'NF && $0 !~ /^[[:space:]]*#/' | shuffle_lines)"

    _selected_mirror=""
    _max_tries="${MAX_MIRROR_TRIES:-5}"
    _i=0

    _old_ifs=$IFS
    IFS='
'
    for _mirror in ${_mirror_list}; do
        _i=$((_i + 1))
        [ "${_i}" -le "${_max_tries}" ] || break

        _url="${_mirror}/${_archive}?source=anttikivi%2Ftoml-zig"
        _signature_url="${_mirror}/${_archive}.minisig?source=anttikivi%2Ftoml-zig"

        echo "trying to download archive from ${_url}..."

        rm -f "${_archive_dest}" "${_archive_dest}.minisig"

        if ! download_archive "${_url}" "${_archive_dest}" 2>/dev/null; then
            continue
        fi

        if ! download_archive "${_signature_url}" "${_archive_dest}.minisig" 2>/dev/null; then
            continue
        fi

        echo "verifying ${_archive} from ${_url}..."

        if minisign -Vm "${_archive_dest}" -x "${_archive_dest}.minisig" -P "${ZIG_PUBLIC_KEY}" >/dev/null 2>&1; then
            _selected_mirror="${_mirror}"
            break
        fi
    done
    unset IFS
    IFS=$_old_ifs

    if [ -z "${_selected_mirror}" ]; then
        echo "failed to download and verify Zig from ${MAX_MIRROR_TRIES} mirrors" >&2
        exit 1
    fi

    echo "downloaded and verified Zig from ${_selected_mirror}" >&2
    rm -f "${_archive_dest}.minisig"

    echo "extracting ${_archive_dest}..."
    case "${_archive_extension}" in
    ".tar.xz")
        tar -C "${_archive_dir}" -xf "${_archive_dest}"
        ;;
    *)
        echo "Zig archive format '${_archive_extension}' not supported" >&2
        exit 1
        ;;
    esac
    rm "${_archive_dest}"

    _extracted_dir="${_archive_dir}/$(basename "${_archive}" "${_archive_extension}")"

    rm -rf "${_dest_dir:?}"
    mkdir -p "$(dirname "${_dest_dir:?}")"

    mv "${_extracted_dir}" "${_dest_dir:?}"

    _zig_bin="${_dest_dir}/zig"
    echo "Zig ${_zig_version} available at ${_zig_bin}"
}

main "$@"
